# Railway 환경변수 설정 예시

# PostgreSQL Database URL (Railway에서 자동 제공)
DATABASE_URL=jdbc:postgresql://localhost:5432/switchon

# JWT Secret (32자 이상 랜덤 문자열)
JWT_SECRET=your-secret-key-here-must-be-at-least-256-bits

# CORS Origins (쉼표로 구분)
CORS_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# Port (Railway에서 자동 제공)
PORT=8080
