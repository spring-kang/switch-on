# Railway нҷҳкІҪліҖмҲҳ м„Өм • мҳҲмӢң
# PostgreSQLмқҖ Railwayм—җм„ң мһҗлҸҷмңјлЎң м•„лһҳ ліҖмҲҳл“Өмқ„ м ңкіөн•©лӢҲлӢӨ

# PostgreSQL (Railway мһҗлҸҷ м ңкіө)
PGHOST=your-db-host.railway.internal
PGPORT=5432
PGDATABASE=railway
PGUSER=postgres
PGPASSWORD=your-password

# JWT Secret (32мһҗ мқҙмғҒ лһңлҚӨ л¬ёмһҗм—ҙ)
JWT_SECRET=your-secret-key-here-must-be-at-least-256-bits

# CORS Origins (мүјн‘ңлЎң кө¬л¶„)
CORS_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# Port (Railway мһҗлҸҷ м ңкіө)
PORT=8080
